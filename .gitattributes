# Normalize all text assets to LF and keep binary assets untouched.
* text=auto eol=lf

*.cs text eol=lf
*.gd text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.cfg text eol=lf
*.json text eol=lf
*.csv text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.shader text eol=lf
*.gdshader text eol=lf

*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.wav binary
*.ogg binary
*.mp3 binary
*.ttf binary
*.otf binary
*.zip binary
